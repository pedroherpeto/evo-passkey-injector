# ── evo-passkey-injector ──────────────────────────────────────────────
# Porta HTTP do injector (interna). Se o zpro estiver em OUTRO host, exponha
# esta porta atras de HTTPS/reverse-proxy — nunca o Postgres.
PORT=8080

# Segredo compartilhado com o zpro (header x-injector-secret). Gere um valor
# forte e cole no painel do zpro (Configuracoes -> Evolution -> Segredo do injector).
#   openssl rand -hex 32
INJECTOR_SECRET=troque-por-um-segredo-forte

# DSN do Postgres do Evolution. Use o NOME DE SERVICO INTERNO da rede evolution-net
# (ex.: postgres:5432) — o sidecar alcanca o banco por dentro. NAO exponha o banco.
EVO_DATABASE_URI=postgres://postgres:typebot@postgres:5432/evolution_db
