# ── evo-passkey-injector ──────────────────────────────────────────────
# Um sidecar, dois backends. Ligue o(s) que voce usa preenchendo as DSNs
# correspondentes — pelo menos UM bloco e obrigatorio.
PORT=8080

# Segredo compartilhado com o zpro (header x-injector-secret). Gere um valor
# forte e cole no painel do zpro (Configuracoes -> Evolution / Evolution Go).
#   openssl rand -hex 32
INJECTOR_SECRET=troque-por-um-segredo-forte

# ── Evolution API (Baileys) — opcional ────────────────────────────────
# DSN do Postgres do Evolution API. Use o NOME DE SERVICO INTERNO da rede
# (ex.: postgres:5432). NAO exponha o banco.
EVO_DATABASE_URI=postgres://postgres:typebot@postgres:5432/evolution_db

# ── Evolution Go (whatsmeow) — opcional ───────────────────────────────
# DOIS bancos no mesmo servidor Postgres do Evolution Go:
#   evogo_auth  = store whatsmeow (whatsmeow_device etc.)
#   evogo_users = instancias (tabela instances)
EVOGO_AUTH_DATABASE_URI=postgres://postgres:senha@evogo-pg:5432/evogo_auth
EVOGO_USERS_DATABASE_URI=postgres://postgres:senha@evogo-pg:5432/evogo_users
